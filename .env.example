# Supabase (Dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Strava — reuse the Sailstats API app (strava.com/settings/api, client ID in sailstats/wrangler.toml)
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
# Local dev; production defaults to https://splicesail.com when unset (see src/lib/app-url.ts)
NEXT_PUBLIC_APP_URL=http://localhost:3000
# NEXT_PUBLIC_APP_URL=https://splicesail.com

# Mapbox — reuse the public token from Sailstats CONFIG.MAPBOX_TOKEN
NEXT_PUBLIC_MAPBOX_TOKEN=

# Club platform approval (new clubs)
SPLICE_PLATFORM_APPROVER_EMAIL=
SPLICE_CLUB_APPROVAL_SECRET=
SUPABASE_SERVICE_ROLE_KEY=
RESEND_API_KEY=
# Verified sender in Resend (defaults to onboarding@resend.dev for testing)
RESEND_FROM_EMAIL=Splice <onboarding@resend.dev>

# Temporary full-site gate (set SPLICE_UNDER_DEVELOPMENT=1 on Vercel)
# SPLICE_UNDER_DEVELOPMENT=1
# Optional: visit /under-development?bypass=YOUR_SECRET to browse while gated
# SPLICE_UNDER_DEVELOPMENT_BYPASS=
